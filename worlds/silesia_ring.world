<?xml version="1.0"?>
<sdf version="1.6">
  <world name="default">

    <!-- Ground and Sun -->
    <include>
      <uri>model://sun</uri>
    </include>

    <!-- Include your racetrack model -->
    <include>
      <uri>model://silesia_ring_model</uri>
      <pose>0 0 0 0 0 0</pose>
    </include>

  </world>
</sdf>
